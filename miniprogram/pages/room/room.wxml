<!-- 自定义状态栏占位 -->
<view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

<!-- 自定义标题栏 -->
<view class="nav-header">
  <view class="back-btn" bindtap="goBack">
    <icon class="iconify" data-icon="heroicons:chevron-left" style="font-size: 24px; color: #94a3b8;"></icon>
  </view>
  <view class="title-group">
    <text class="room-id">房间 ID: {{roomNumber}}</text>
    <view class="status-badge">
      <view class="dot"></view>
      <text>进行中</text>
    </view>
  </view>
  <view class="settings-btn">
    <icon class="iconify" data-icon="heroicons:cog-6-tooth" style="font-size: 20px; color: #94a3b8;"></icon>
  </view>
</view>

<scroll-view scroll-y class="main-container hide-scrollbar">
  <!-- 房间状态卡片 -->
  <view class="room-card">
    <view class="card-content">
      <view class="top-row">
        <view>
          <text class="label">当前房间</text>
          <text class="room-name">{{roomInfo.name || '正在加载...'}}</text>
        </view>
        <view class="status-tag">ACTIVE</view>
      </view>
      <view class="bottom-row">
        <view class="stat-item">
          <text class="stat-label">当前积分</text>
          <text class="stat-value">55</text>
        </view>
        <view class="stat-item">
          <text class="stat-label">已进行</text>
          <text class="stat-value">02:45:12</text>
        </view>
        <view class="card-footer">
          <text class="date">2026.02.04</text>
          <text class="creator">创建者: 果果</text>
          <view class="invite-btn" bindtap="onInvite">
            <icon class="iconify" data-icon="heroicons:share" style="font-size: 12px; margin-right: 4px;"></icon>
            邀请好友
          </view>
        </view>
      </view>
    </view>
    <icon class="card-bg-icon iconify" data-icon="heroicons:trophy"></icon>
  </view>

  <!-- 实时积分榜 -->
  <view class="section-header">
    <text class="section-title">实时积分榜</text>
    <view class="avatar-stack">
      <image wx:for="{{members}}" wx:key="userId" src="{{item.roomAvatar}}" class="stack-img"></image>
    </view>
  </view>

  <view class="member-list">
    <view class="member-item" wx:for="{{members}}" wx:key="userId" bindtap="onMemberTap" data-member="{{item}}">
      <view class="member-left">
        <view class="avatar-box">
          <image src="{{item.roomAvatar}}" class="avatar"></image>
          <view class="rank-badge rank-{{index + 1}}">{{index + 1}}</view>
        </view>
        <view>
          <text class="nickname">{{item.roomNickname}}</text>
          <text class="desc">发挥稳定</text>
        </view>
      </view>
      <view class="member-right">
        <text class="balance {{item.balance >= 0 ? 'positive' : 'negative'}}">{{item.balance > 0 ? '+' : ''}}{{item.balance}}</text>
      </view>
    </view>
  </view>

  <!-- 转账记录 -->
  <view class="section-header mt-6">
    <text class="section-title">转账记录</text>
  </view>
  <view class="history-list">
    <view class="history-item" wx:for="{{transfers}}" wx:key="id">
      <view class="item-left">
        <text class="time">{{item.time}}</text>
        <text class="log"><text class="me">我</text> → <text class="target">{{item.receiverName}}</text></text>
      </view>
      <text class="amount">+{{item.amount}}</text>
    </view>
  </view>
</scroll-view>

<!-- 底部结算按钮 -->
<view class="bottom-bar">
  <button class="settle-btn" bindtap="onSettleTap">一键结算并退出</button>
</view>

<!-- 数字键盘抽屉 (Numpad) -->
<view class="drawer-mask" wx:if="{{showNumpad}}" bindtap="closeNumpad">
  <view class="numpad-drawer" catchtap="stopBubble">
    <view class="drawer-header">
      <view class="target-info">
        <image src="{{selectedMember.roomAvatar}}" class="target-avatar"></image>
        <view>
          <text class="target-name">给 {{selectedMember.roomNickname}} 记分</text>
          <text class="target-sub">积分将从你的账户转出</text>
        </view>
      </view>
      <icon class="iconify close-icon" data-icon="heroicons:x-mark" bindtap="closeNumpad"></icon>
    </view>

    <view class="amount-display">
      <text class="amount-num">{{amount || '0'}}</text>
      <text class="amount-unit">积分</text>
    </view>

    <view class="numpad-grid">
      <view class="num-key" wx:for="{{[1,2,3,4,5,6,7,8,9,'.',0]}}" wx:key="*this" bindtap="onNumTap" data-num="{{item}}">{{item}}</view>
      <view class="num-key delete" bindtap="onDeleteTap">
        <icon class="iconify" data-icon="heroicons:arrow-left-start-on-rectangle" style="transform: rotate(90deg);"></icon>
      </view>
    </view>

    <button class="confirm-btn {{amount ? 'active' : ''}}" bindtap="submitTransfer">确认并记分</button>
  </view>
</view>