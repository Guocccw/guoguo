<!-- 自定义状态栏占位 -->
<view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
<!-- 顶部导航栏 -->
<view class="nav-header">
  <view class="back-btn" bindtap="goBack">
    <view class="icon icon-back"></view>
  </view>
  <view class="title-container">
    <text class="room-id">房间号: {{roomNumber}}</text>
    <view class="status-indicator">
      <view class="dot-pulse"></view>
      <text>进行中</text>
    </view>
  </view>
  <view class="settings-btn">
    <view class="icon icon-settings"></view>
  </view>
</view>
<scroll-view scroll-y class="main-container hide-scrollbar">
  <!-- 核心：房间状态卡片 -->
  <view class="room-card">
    <view class="card-inner">
      <view class="card-header-row">
        <view class="title-box">
          <text class="label-tiny">当前房间</text>
          <text class="room-name">{{roomInfo.name}}</text>
        </view>
        <view class="active-badge">ACTIVE</view>
      </view>
      <view class="card-stats-row">
        <view class="stat-group">
          <view class="stat-box">
            <text class="stat-label">当前积分</text>
            <text class="stat-value big-font">{{currentBalance || 0}}</text>
          </view>
          <view class="stat-box mt-4">
            <text class="stat-label">已进行</text>
            <text class="stat-value font-mono">{{elapsedTime || '00:00:00'}}</text>
          </view>
        </view>
        <view class="stat-info-right text-right">
          <text class="date-text">{{roomDate || ''}}</text>
          <text class="creator-text">创建者: {{creatorName || ''}}</text>
          <!-- <view class="invite-action" bindtap="onInvite">
            <view class="icon icon-share-white"></view>
            <text>邀请好友</text>
          </view> -->
        </view>
      </view>
    </view>
    <!-- 背景装饰图标 -->
    <view class="icon-trophy-bg"></view>
  </view>
  <!-- 实时排行列表 -->
  <view class="section-title-row">
    <text class="section-h">成员动态</text>
    <view class="member-count">{{members.length}}</view>
    <view class="flex-spacer"></view>
    <view class="invite-mini-btn" bindtap="onInvite">
      <view class="icon icon-user-plus"></view>
      <text>邀好友</text>
    </view>
  </view>
  <view class="member-grid">
    <view class="member-card-item" wx:for="{{members}}" wx:key="userId" bindtap="onMemberTap" data-member="{{item}}">
      <view class="member-main">
        <view class="avatar-wrap">
          <image src="{{item.roomAvatar}}" class="avatar-img"></image>
          <view class="rank-medal rank-color-{{index + 1}}">{{index + 1}}</view>
        </view>
        <view class="member-info">
          <text class="m-name">{{item.roomNickname}}</text>
          <text class="m-desc"></text>
        </view>
      </view>
      <view class="member-score">
        <text class="score-num {{item.score >= 0 ? 'text-dark' : 'text-red'}}">
          {{item.score > 0 ? '+' : ''}}{{item.score}}
        </text>
        <text class="score-unit">余额</text>
      </view>
    </view>
  </view>
  <!-- 实时转分流水 -->
  <view class="section-title-row mt-6">
    <view class="icon icon-transfer-gray mr-2"></view>
    <text class="section-h-gray">实时转分记录</text>
  </view>
  <view class="ledger-container">
    <view class="no-data" wx:if="{{transfers.length === 0}}">
      <view class="icon icon-history-light mb-2"></view>
      <text>点击成员头像开始记分</text>
    </view>
    <view class="ledger-item" wx:for="{{transfers}}" wx:key="id">
      <view class="ledger-left">
        <text class="l-time">{{item.time}}</text>
        <view class="l-content">
          <text class="l-me">我</text>
          <text class="l-arrow">→</text>
          <text class="l-target">{{item.receiverName}}</text>
        </view>
      </view>
      <text class="l-amount">+{{item.amount}}</text>
    </view>
  </view>
  <view class="safe-area-inset"></view>
</scroll-view>
<!-- 底部固定操作栏 -->
<view class="footer-fixed">
  <button class="primary-action-btn1" bindtap="onExitRoom">退出房间</button>
  <button class="primary-action-btn2" bindtap="onSettleTap">一键结算并退出</button>
</view>
<!-- 记分键盘抽屉 -->
<view class="drawer-overlay {{showNumpad ? 'show' : ''}}" bindtap="closeNumpad">
  <view class="numpad-content" catchtap="stopBubble">
    <view class="numpad-header">
      <view class="target-profile">
        <view class="target-avatar-wrap">
          <image src="{{selectedMember.roomAvatar}}" class="t-avatar"></image>
          <view class="t-plus-icon">+</view>
        </view>
        <view class="t-text">
          <text class="t-name">给 {{selectedMember.roomNickname}} 记分</text>
          <text class="t-hint">分值将从你的账户转出到对方</text>
        </view>
      </view>
      <view class="close-btn" bindtap="closeNumpad">
        <view class="icon icon-close-gray"></view>
      </view>
    </view>
    <view class="numpad-display">
      <text class="display-num">{{amount || '0'}}</text>
      <text class="display-unit">POINTS</text>
    </view>
    <view class="keyboard-grid">
      <view class="key" wx:for="{{[1,2,3,4,5,6,7,8,9,'.',0]}}" wx:key="*this" bindtap="onNumTap" data-num="{{item}}">
        {{item}}
      </view>
      <view class="key key-del" bindtap="onDeleteTap">
        <view class="icon icon-backspace"></view>
      </view>
    </view>
    <button class="numpad-submit {{amount ? 'active' : ''}}" bindtap="submitTransfer">确认并记分</button>
  </view>
</view>