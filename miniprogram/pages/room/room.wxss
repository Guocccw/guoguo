/* 之前已有的样式保持不变... */
.nav-header {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  background: #fff;
}

.title-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.room-id {
  font-size: 14px;
  font-weight: 900;
  color: #1e293b;
}

.status-badge {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 2px;
}

.status-badge .dot {
  width: 4px;
  height: 4px;
  background: #22c55e;
  border-radius: 50%;
  animation: pulse 2s infinite;
}

.status-badge text {
  font-size: 9px;
  font-weight: 900;
  color: #22c55e;
  text-transform: uppercase;
}

.main-container {
  flex: 1;
  padding: 16px 20px;
}

.room-card {
  background: linear-gradient(135deg, #4caf50, #2e7d32);
  border-radius: 20px;
  padding: 20px;
  color: #fff;
  position: relative;
  overflow: hidden;
  box-shadow: 0 10px 25px -5px rgba(76, 175, 80, 0.3);
}

.card-bg-icon {
  position: absolute;
  right: -20px;
  bottom: -20px;
  width: 160px;
  height: 160px;
  opacity: 0.1;
  transform: rotate(12deg);
}

.member-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px;
  background: #fff;
  border: 1px solid #f8fafc;
  border-radius: 24px;
  margin-bottom: 12px;
  box-shadow: 0 1px 2px rgba(0,0,0,0.05);
}

.avatar-box {
  position: relative;
  margin-right: 12px;
}

.avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 2px solid #f1f5f9;
}

.rank-badge {
  position: absolute;
  top: -4px;
  left: -4px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  font-size: 9px;
  font-weight: 900;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid #fff;
}

.rank-1 { background: #fbbf24; }
.rank-2 { background: #cbd5e1; }
.rank-3 { background: #fb923c; }

.balance {
  font-size: 20px;
  font-weight: 900;
  font-style: italic;
}

.positive { color: #1e293b; }
.negative { color: #f87171; }

.bottom-bar {
  height: 112px;
  padding: 0 32px;
  display: flex;
  align-items: center;
  background: #fff;
  border-top: 1px solid #f1f5f9;
}

.settle-btn {
  width: 100%;
  height: 56px;
  background: #1e293b;
  color: #fff;
  border-radius: 24px;
  font-weight: 900;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 抽屉键盘样式 */
.drawer-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.4);
  backdrop-filter: blur(4px);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.numpad-drawer {
  width: 100%;
  background: #fff;
  border-radius: 40px 40px 0 0;
  padding: 32px;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.numpad-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.num-key {
  height: 64px;
  background: #fff;
  border: 1px solid #f1f5f9;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: 900;
  color: #334155;
}

.num-key:active { background: #f8fafc; }

.confirm-btn {
  margin-top: 24px;
  height: 60px;
  border-radius: 24px;
  background: #f1f5f9;
  color: #cbd5e1;
  font-weight: 900;
}

.confirm-btn.active {
  background: #4caf50;
  color: #fff;
  box-shadow: 0 20px 25px -5px rgba(76, 175, 80, 0.2);
}