.hide-scrollbar::-webkit-scrollbar { display: none; }

/* 基础图标类 */
.icon {
  display: inline-block;
  width: 20px;
  height: 20px;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  vertical-align: middle;
}

