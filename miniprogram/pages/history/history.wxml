<view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
<view class="nav-header">
  <view class="back-btn" bindtap="goBack">
    <view class="icon icon-back"></view>
  </view>
  <view class="title-container">
    <text class="page-title">全部战绩</text>
    <text class="page-subtitle">{{historyList.length}} 条记录</text>
  </view>
  <view class="nav-placeholder"></view>
</view>

<scroll-view scroll-y class="main-container hide-scrollbar" enhanced>
  <view class="no-data" wx:if="{{!historyLoading && historyList.length === 0}}">
    <view class="icon icon-empty-box mb-4"></view>
    <text>还没有参与过任何对局哦</text>
  </view>

  <view class="history-list" wx:else>
    <view class="history-card" wx:for="{{historyList}}" wx:key="id" bindtap="viewRoomDetail" data-item="{{item}}">
      <view class="h-left">
        <view class="h-icon {{item.score >= 0 ? 'bg-green-light' : 'bg-red-light'}}">
          <view class="icon {{item.score >= 0 ? 'icon-trending-up' : 'icon-trending-down'}}"></view>
        </view>
        <view class="h-info">
          <text class="h-name">{{item.roomName}} #{{item.roomNumber}}</text>
          <text class="h-date">{{item.createdAt}}</text>
        </view>
      </view>
      <view class="h-right">
        <text class="h-profit {{item.score >= 0 ? 'text-green' : 'text-red'}}">
          {{item.score >= 0 ? '+' : ''}}{{item.score}}
        </text>
        <view class="icon icon-chevron-right-gray ml-4"></view>
      </view>
    </view>
  </view>

  <view class="safe-area-bottom"></view>
</scroll-view>
