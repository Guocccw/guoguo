page {
  background-color: #f8f9fa;
  width: 100vw;
  overflow-x: hidden;
}

.hide-scrollbar::-webkit-scrollbar { display: none; }

.status-bar {
  width: 100%;
}

/* 导航栏 */
.nav-header {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  background: #fff;
}

.nav-title {
  font-size: 16px;
  font-weight: 900;
  color: #1e293b;
}

.back-btn, .placeholder {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 头像区 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.avatar-wrapper {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
}

.main-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #fff;
  border: 8rpx solid #fff;
  box-shadow: 0 20rpx 40rpx rgba(76, 175, 80, 0.15);
}

.camera-icon {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 64rpx;
  height: 64rpx;
  background: #4caf50;
  border-radius: 50%;
  border: 4rpx solid #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}

.avatar-hint {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 600;
}

/* 资料卡片 */
.profile-card {
  margin: 0 40rpx;
  background: #fff;
  border-radius: 48rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}

.input-group {
  margin-bottom: 48rpx;
}

.input-label {
  display: block;
  font-size: 22rpx;
  font-weight: 900;
  color: #cbd5e1;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.nickname-input {
  width: 100%;
  height: 100rpx;
  background: #f8fafc;
  border-radius: 24rpx;
  padding: 0 40rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #1e293b;
}

.placeholder-style {
  color: #cbd5e1;
}

/* 预设头像 */
.preset-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-top: 10rpx;
}

.preset-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 20rpx;
  overflow: hidden;
  background: #f8fafc;
  border: 4rpx solid transparent;
}

.preset-item.active {
  border-color: #4caf50;
}

.preset-img {
  width: 100%;
  height: 100%;
}

.check-mark {
  position: absolute;
  inset: 0;
  background: rgba(76, 175, 80, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 底部按钮 */
.bottom-action {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 40rpx 60rpx 80rpx;
  background: linear-gradient(to top, #f8f9fa 80%, rgba(248, 249, 250, 0));
  box-sizing: border-box;
}

.save-btn {
  width: 100% !important;
  height: 112rpx;
  background: #4caf50;
  color: #fff;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 40rpx rgba(76, 175, 80, 0.2);
  border: none !important;
}

.save-btn::after { display: none; }

.tip-section {
  padding: 40rpx 80rpx 200rpx;
  text-align: center;
}

.tip-text {
  font-size: 22rpx;
  color: #cbd5e1;
  font-weight: 600;
  line-height: 1.6;
}

/* 图标 */
